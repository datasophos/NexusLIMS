# Test environment variables for NexusLIMS
# This file is loaded by tests/unit/conftest.py if it exists
# Variables here will be available during testing but won't override
# the hardcoded test environment variables set in conftest.py

# IMPORTANT: All test environment variables MUST start with NX_TESTS_*
# to be loaded into the environment. This naming convention prevents
# conflicts with actual application variables and ensures test isolation.

# NX_TESTS_KEEP_DOCKER_RUNNING - Controls whether Docker containers
# should be kept running after integration tests complete.
# Set to "1" to keep containers running for debugging.
# Set to "0" or unset to stop containers after tests (default behavior).
NX_TESTS_KEEP_DOCKER_RUNNING=0
# NX_TESTS_KEEP_DOCKER_RUNNING=1

# Note: The main test configuration (paths, database, etc.) is still
# controlled by tests/unit/conftest.py to ensure test isolation and reproducibility

# --- LabArchives live integration test credentials ----------------------------
# Used by tests/integration/test_labarchives_integration.py (-m labarchives_live)
# Run with: uv run pytest tests/integration/test_labarchives_integration.py -m labarchives_live -v

NX_LABARCHIVES_URL=https://api.labarchives.com/api
NX_LABARCHIVES_ACCESS_KEY_ID=your-akid
NX_LABARCHIVES_ACCESS_PASSWORD=your-hmac-signing-secret
NX_LABARCHIVES_USER_ID=your-uid

# Notebook ID to use for tree / entry tests.
# The tests will create folders and pages inside this notebook.
# Use a dedicated test notebook to keep test artifacts separate from real work.
NX_LABARCHIVES_NOTEBOOK_ID=your-test-notebook-id

# Your LabArchives login email and external app password.
# The external app password is found in the LabArchives web UI under:
#   (your username, top-right) → External App authentication
# These are only required for TestLabArchivesUserInfo.test_get_user_info_with_credentials.
NX_LABARCHIVES_TEST_EMAIL=you@example.com
# this expires after 1 hour, so will often need to be reset:
NX_LABARCHIVES_TEST_LA_PASSWORD=your-external-app-password
